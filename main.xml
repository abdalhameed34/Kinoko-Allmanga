<RefreshLayout id="refresh" layout_width="match_parent" layout_height="match_parent">
    <list id="list">
        <item>
            <column padding="16">
                <text text="${item.title}" textSize="18" textColor="#000000" bold="true" />
                <text text="${item.subtitle}" textSize="14" textColor="#888888" margin="0,4,0,0" />
            </column>
        </item>
    </list>
</RefreshLayout>
